import pathlib, sys

TARGET = pathlib.Path('src/nouveau/vulkan/nvk_nv_low_latency2.c')

if TARGET.exists():
    existing = TARGET.read_text()
    if 'll2_sleep_thread' in existing and 'NVK_LL2_TOMBSTONE' in existing:
        print("==> nvk_nv_low_latency2.c: v2 already present — skipping.")
